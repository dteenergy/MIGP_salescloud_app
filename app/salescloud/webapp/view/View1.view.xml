<mvc:View controllerName="com.sap.salescloud.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:x="sap.uxap">

    <!-- <Page id="page" title="" titleAlignment="Center"> -->
    <Page id="page" title="" titleAlignment="Center" showHeader="false">
    <content>
          <!-- ── Context Banner — shows OPP or QUOTE context ── -->
    <MessageStrip
        id="idContextBanner"
        text="{= ${oSCDetail>/isQuoteContext} === true
            ? 'Quote : ' + ${oSCDetail>/quoteId} + ' ( Linked to Opportunity ' + ${oSCDetail>/Oppid} + ' )'
            : 'Opportunity : ' + ${oSCDetail>/Oppid} }"
        type="{= ${oSCDetail>/isQuoteContext} === true ? 'Information' : 'Information' }"
        showIcon="true"
        showCloseButton="false"
        class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop">
    </MessageStrip>
        <!-- ═══════════════════════════════════════════════════════════════════
             HEADER FORM — FDD Section 5.3
             Layout: 2 columns, 5 rows each side — matching screenshot exactly
             LEFT  col: Opp ID | Status | Size of Opp | Annual Subscribed Load | Contract Lifetime Value | Price Structure | NTE | Metered Con (LCVP)
             RIGHT col: Opp Category | Term (LCVP) | Gross Annual Usage | Sub% | Annual MWh at Close | Opp Subscribed Load | Sales Type | Unmetered Con (LCVP)
        ════════════════════════════════════════════════════════════════════ -->
        <form:SimpleForm id="idCustomerInfoReqForm_CC"
            editable="true"
            layout="ResponsiveGridLayout"
            singleContainerFullSize="false"
            columnsXL="2" columnsL="2"
            labelSpanXL="5" labelSpanL="5"
            labelSpanM="12" labelSpanS="12"
            emptySpanXL="0" emptySpanL="0">
          <form:content>

            <!-- ════════ LEFT COLUMN ════════ -->
            <!-- <core:Title id="_IDGenTitle1_CC" text="{i18n>opp}" icon="sap-icon://opportunities"/> -->

            <!-- Row 1 L: Opportunity ID — plain Input, fetch on Enter or suggestion select -->
            <Label id="idlbloppid" text="{i18n>oppid}"/>
            <Input id="il8"
                placeholder="Enter Opportunity ID"
                showSuggestion="true"
                suggest="onOppIdSuggest"
                suggestionItemSelected="onOppIdSuggestionSelected"
                submit="onFetchOpp"
                tooltip="Type to search" editable="false">
              <layoutData><l:GridData id="_IDGenGridData1" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- ← ADD THIS BLOCK RIGHT HERE — Row 1b L: Quote ID row (visible only in Quote context) -->
<Label id="idlblquoteid" text="Quote ID"
    visible="{= ${oSCDetail>/isQuoteContext} === true }"/>
<Input id="idquoteid"
    value="{oSCDetail>/quoteId}"
    editable="false"
    tooltip="Sales Quote ID passed from C4C"
    visible="{= ${oSCDetail>/isQuoteContext} === true }">
  <layoutData><l:GridData id="_IDGenGridData_quoteId" span="XL7 L7 M12 S12"/></layoutData>
</Input>
<!-- ── END Quote ID row ── -->

            <!-- Row 2 L: Status -->
            <Label id="idlblstatus" text="{i18n>stat}"/>
            <!-- <ComboBox id="idstatus" selectionChange="onComboBoxtype" editable="false" enabled="false" >
                <core:Item id="_IDGenItem" key="In Progress"       text="{i18n>prog}"/>
                <core:Item id="_IDGenItem1" key="Structuring"        text="{i18n>str}"/>
                <core:Item id="_IDGenItem2" key="In Approval"        text="{i18n>inApp}"/>
                <core:Item id="_IDGenItem3" key="Approved"           text="{i18n>appr}"/>
                <core:Item id="_IDGenItem4" key="Rejected"           text="{i18n>rej}"/>
                <core:Item id="_IDGenItem5" key="Contract Sign-Off"  text="{i18n>con}"/>
                <core:Item id="_IDGenItem6" key="Closed"             text="{i18n>close}"/>
                <layoutData><l:GridData id="_IDGenGridData2" span="XL7 L7 M12 S12"/></layoutData>
            </ComboBox> -->
            <!-- <Input id="idstatus" 
                   value="{oSCDetail>/status}" 
                   editable="false"
                    tooltip="Status is managed by SAP Sales Cloud">
               <layoutData>
                  <l:GridData id="_IDGenGridData2" span="XL7 L7 M12 S12"/>
                </layoutData>
            </Input> -->
            <!-- Opportunity context: status is read-only, managed by SAP Sales Cloud -->
<Input id="idstatus"
       value="{oSCDetail>/status}"
       editable="false"
       tooltip="Status is managed by SAP Sales Cloud"
       visible="{= ${oSCDetail>/isQuoteContext} === false }">
    <layoutData>
        <l:GridData id="_IDGenGridData2" span="XL7 L7 M12 S12"/>
    </layoutData>
</Input>

<!-- Quote context: status is editable with fixed allowed values -->
<ComboBox id="idQuoteStatus"
          selectedKey="{oSCDetail>/status}"
          visible="{= ${oSCDetail>/isQuoteContext} === true }"
          enabled="false"
          tooltip="Quote status">
    <items>
        <core:Item id="_IDGenItem1" key="Open"        text="Open"/>
        <core:Item id="_IDGenItem2" key="In Progress" text="In Progress"/>
        <core:Item id="_IDGenItem3" key="Structuring" text="Structuring"/>
        <core:Item id="_IDGenItem4" key="Won"         text="Won"/>
        <core:Item id="_IDGenItem5" key="Lost"        text="Lost"/>
        <core:Item id="_IDGenItem6" key="Closed"      text="Closed"/>
    </items>
    <layoutData>
        <l:GridData id="_IDGenGridData" span="XL7 L7 M12 S12"/>
    </layoutData>
</ComboBox>
            <!-- Change 1 — ADD Sales Phase after Status Input: -->
              <Label id="idlblsalesPhase" text="Sales Phase"/>
            <!-- visible="{= ${oSCDetail>/isQuoteContext} === false }"/> -->
              <ComboBox id="idsalesPhase"
                        selectedKey="{oSCDetail>/salesPhase}"
                         selectionChange="onSalesPhaseChange">
           <!-- visible="{= ${oSCDetail>/isQuoteContext} === false }">/ -->
              <layoutData>
                <l:GridData id="_IDGenGridData_salesphase" span="XL7 L7 M12 S12"/>
            </layoutData>
              </ComboBox>

            <!-- Row 7 R: Sales Type -->
            <Label id="idlblEmerCnNme_CC" text="{i18n>salestyp}"/>
            <ComboBox id="idMode_S" selectionChange="onComboBoxtype">
                <core:Item id="_IDGenItem11" key="New"           text="New Sale"/>
                <core:Item id="_IDGenItem12" key="Amendment"     text="Amendment"/>
                <core:Item id="_IDGenItem13" key="Renewal"       text="Renewal"/>
                <!-- <core:Item id="_IDGenItem14" key="One-time Sale" text="One-time Sale"/> -->
                <layoutData><l:GridData id="_IDGenGridData17" span="XL7 L7 M12 S12"/></layoutData>
            </ComboBox>

            <!-- Row 3 R: Gross Annual Usage -->
            <Label id="idlblusage" text="{i18n>grossusage}"/>
            <Input id="idusage" value="{path: 'oSCDetail>/annualGross' , formatter: '.formatThousands' }" editable="false">
              <layoutData><l:GridData id="_IDGenGridData13" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Row 3 L: Size of Opportunity -->
            <Label id="idlblsize" text="{i18n>sizeopp}"/>
            <Input id="idsize" value="{ path: 'oSCDetail>/sizeofOpp', formatter: '.formatThousands' }" editable="false">
              <layoutData><l:GridData id="_IDGenGridData3" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Row 4 R: Estimated Subscription % -->
            <Label id="idlblpusage" text="{i18n>subest}"/>
            <Input id="idpusage" value="{oSCDetail>/percentUsage}" description="%">
              <layoutData><l:GridData id="_IDGenGridData14" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Row 2 R: Term (LCVP, hidden by default) -->
            <Label id="idlterm" text="{i18n>term}" visible="false"/>
            <Input id="idterm" value="{oSCDetail>/term}" editable="false" visible="false">
              <layoutData><l:GridData id="_IDGenGridData12" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

           

            <!-- Row 6 L: Price Structure -->
            <Label id="idlblEmerConNme_CC" text="{i18n>pricestr}"/>
            <ComboBox id="idMode_CS" selectionChange="onComboBoxtype">
                <core:Item id="_IDGenItem7" key="REC Blend"  text="REC Blend"/>
                <core:Item id="_IDGenItem8" key="Full Price" text="Full Price"/>
                <layoutData><l:GridData id="_IDGenGridData6" span="XL7 L7 M12 S12"/></layoutData>
            </ComboBox>

            <!-- Row 7 L: NTE Price -->
            <Label id="idlblnte" text="{i18n>nte}"/>
            <Input id="idnte" value="{oSCDetail>/nte}">
              <layoutData><l:GridData id="_IDGenGridData7" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Row 10 R: Include in Upcoming Pipeline -->
            <!-- <Label id="idlblincludePipeline" text="Include in Upcoming Pipeline"/>
            <CheckBox id="idincludePipeline"
                selected="{path: 'oSCDetail>/includeInPipeline', type: 'sap.ui.model.type.Boolean'}"
                tooltip="Reporting indicator for weekly pipeline meetings (FDD #18)">
              <layoutData><l:GridData id="_IDGenGridData20" span="XL7 L7 M12 S12"/></layoutData>
            </CheckBox> -->

            <!-- ════════ RIGHT COLUMN ════════ -->
            <core:Title id="_IDGenTitle2_CC"/>

            <!-- Row 1 R: Opportunity Category -->
            <!-- <Label id="idlblEmerConName_CC" text="{i18n>oppcat}"/> -->
            <Label id="idlblEmerConName_CC" text="{= ${oSCDetail>/isQuoteContext} === true ? 'Quote Category' : 'Opportunity Category' }"/>
            <ComboBox id="idModel_CS" selectionChange="onComboBoxtype"  editable="false"  enabled="false" class="noGreyCombo">
                <core:Item id="_IDGenItem9" key="MIGP - Small Business" text="MIGP - Small Business"/>
                <core:Item id="_IDGenItem10" key="MIGP - LCVP"                  text="MIGP - LCVP"/>
                <core:Item id="_IDGenItem100" key="MIGP - Dedicated Array"      text="MIGP - Dedicated Array"/>
                <layoutData><l:GridData id="_IDGenGridData11" span="XL7 L7 M12 S12"/></layoutData>
            </ComboBox>

            
             <!-- Row 4 L: Annual Subscribed Load -->
            <Label id="idlblsubs" text="{i18n>anualsubs}"/>
            <Input id="idsubs" value="{path:'oSCDetail>/annualSubs', formatter: '.formatThousands' }"  editable="false">
              <layoutData><l:GridData id="_IDGenGridData4" span="XL7 L7 M12 S12"/></layoutData>
            </Input>


             <!-- Row 6 R: Opportunity Subscribed Load -->
            <Label id="idlblfee" text="{i18n>oppsubs}"/>
            <Input id="idfee" value="{path: 'oSCDetail>/oppSubs' , formatter: '.formatThousands' }" editable="false">
              <layoutData><l:GridData id="_IDGenGridData16" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Row 5 L: Contract Lifetime Value -->
            <Label id="idlblcontract" text="{i18n>conlife}"/>
            <Input id="idcontract" value="{path:'oSCDetail>/contLifetimeval', formatter: '.formatThousands' }" editable="false">
              <layoutData><l:GridData id="_IDGenGridData5" span="XL7 L7 M12 S12"/></layoutData>
            </Input>
            

            

            <!-- Row 5 R: Annual MWh Size at Closure -->
            <!-- <Label id="idlblclosure" text="{i18n>annclosure}"/>
            <Input id="idclosure" value="{oSCDetail>/annualMWh}">
              <layoutData><l:GridData id="_IDGenGridData15" span="XL7 L7 M12 S12"/></layoutData>
            </Input> -->

           
            <!-- Row 8 L: Metered Consumption (LCVP only, hidden by default) -->
            <Label id="idlblmtrcon" text="{i18n>mtrcon}" visible="false"/>
            <Input id="idmtrcon" value="{path :'oSCDetail>/meteredCon' , formatter: '.formatThousands' }" editable="false" visible="false">
              <layoutData><l:GridData id="_IDGenGridData8" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

             <!-- Row 8 R: Unmetered Consumption (LCVP only, hidden by default) -->
            <Label id="idlblunmtrcon" text="{i18n>unmtrcon}" visible="false"/>
            <Input id="idunmtrcon" value="{path :'oSCDetail>/unmeteredCon' , formatter: '.formatThousands' }" editable="false" visible="false">
              <layoutData><l:GridData id="_IDGenGridData18" span="XL7 L7 M12 S12"/></layoutData>
            </Input>


            <!-- Row 9 L: Commencement Letter Sent (LCVP, Sales Admins) -->
            <Label id="idlblcommLetterSent" text="Commencement Letter Sent" visible="false"/>
            <CheckBox id="idcommLetterSent"
                selected="{path: 'oSCDetail>/commencementLetterSent', type: 'sap.ui.model.type.Boolean'}"
                visible="false"
                enabled="false"
                tooltip="Indicator only — no downstream impact (FDD #11)">
              <layoutData><l:GridData id="_IDGenGridData9" span="XL7 L7 M12 S12"/></layoutData>
            </CheckBox>

            <!-- Row 9 R: Commencement Letter Signed (LCVP, Sales Admins) -->
            <Label id="idlblcommLetterSigned" text="Commencement Letter Signed" visible="false"/>
            <CheckBox id="idcommLetterSigned"
                selected="{path: 'oSCDetail>/commencementLetterSigned', type: 'sap.ui.model.type.Boolean'}"
                visible="false"
                enabled="false"
                tooltip="Indicator only — no downstream impact (FDD #12)">
              <layoutData><l:GridData id="_IDGenGridData19" span="XL7 L7 M12 S12"/></layoutData>
            </CheckBox>

            <!-- Row 10 L: Enrolled — free-text display, comma-separated values from CR&B -->
            <!-- e.g. "MIGP-FIXED" | "MIGP-FLEX" | "LCVP" | "MIGP-FLEX,LCVP" (FDD #13) -->
            <!-- <Label id="idlblenrolled" text="Enrolled"/>
            <Input id="idenrolled" value="{oSCDetail>/enrolled}" editable="false"
                tooltip="Values returned by CR&amp;B e.g. MIGP-FIXED, MIGP-FLEX, LCVP (comma-separated if multiple)">
              <layoutData><l:GridData id="_IDGenGridData10" span="XL7 L7 M12 S12"/></layoutData>
            </Input> -->

            

           
            

            
            <!-- Last Fetch timestamp — read-only header field -->
<Label id="idlblLastFetch" text="Last Fetched"/>
<Input id="idLastFetch"
    value="{oSCDetail>/lastFetchedAt}"
    editable="false"
    tooltip="Date and time of the last CA Fetch/Validate for this Opportunity">
  <layoutData><l:GridData id="_IDGenGridData_lastFetch" span="XL7 L7 M12 S12"/></layoutData>
</Input>
            <!-- Enrollment Referral Code — SMB only -->
            <Label id="idlblReferralCode" text="Referral Code"
                visible="{= ${oSCDetail>/oppCategory} === 'MIGP - Small Business' }"/>
            <Input id="idReferralCode"
                value="{oSCDetail>/enrollmentReferralCode}"
                maxLength="15"
                placeholder="e.g. TONY"
                tooltip="Enrollment Referral Code — corresponds to ISU table entry"
                visible="{= ${oSCDetail>/oppCategory} === 'MIGP - Small Business' }">
              <layoutData><l:GridData id="_IDGenGridData15" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

            <!-- Enrollment Email ID — SMB only -->
            <Label id="idlblEnrollmentEmail" text="Enrollment Email ID"
                visible="{= ${oSCDetail>/oppCategory} === 'MIGP - Small Business' }"/>
            <Input id="idEnrollmentEmail"
                value="{oSCDetail>/enrollmentEmailId}"
                placeholder="email@example.com"
                tooltip="Email ID for MIGP welcome letter"
                visible="{= ${oSCDetail>/oppCategory} === 'MIGP - Small Business' }">
              <layoutData><l:GridData id="_IDGenGridData21" span="XL7 L7 M12 S12"/></layoutData>
            </Input>

         
          </form:content>
        </form:SimpleForm>

    </content>

    <!-- ═════════════════════════════════════════════════════════════════════
         TABS — FDD Section 5.4
    ══════════════════════════════════════════════════════════════════════ -->
    <IconTabBar id="idIconTabBarNoIcons" expanded="{device>/isNoPhone}" class="sapUiResponsiveContentPadding">
      <items>

        <!-- ── TAB 1: Involved Parties (FDD Tab#1) ─────────────────────── -->
        <IconTabFilter id="_IDGenIconTabFilter" text="{i18n>invparty}" key="info">
          <OverflowToolbar id="idToolbarIP">
    <ToolbarSpacer id="idSpacerIP"/>
    <Button id="idbtnIPSort" icon="sap-icon://sort" type="Ghost"
            tooltip="Sort and Filter Involved Parties"
            press="onSortFilterIP"/>
  </OverflowToolbar>
          <Table id="table" fixedLayout="false" items="{oOpportunityjmodel>/InvolvedParties}">
            <columns>
              <Column id="_IDGenColumn"><Text id="_IDGenText" text="{i18n>buspartner}"/></Column>
              <Column id="_IDGenColumn1"><Text id="_IDGenText2" text="{i18n>role}"/></Column>
            </columns>
            <items>
              <ColumnListItem id="_IDGenColumnListItem">
                <cells>
                  <Text id="_IDGenText3" text="{oOpportunityjmodel>buspartner}"/>
                  <Text id="_IDGenText4" text="{oOpportunityjmodel>role}"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </IconTabFilter>

        <IconTabSeparator id="_IDGenIconTabSeparator"/>

        <!-- ── TAB 2: CA Consumption Details (FDD Tab#2) ──────────────── -->
<IconTabFilter id="_IDGenIconTabFilter1" text="{i18n>consumption}" key="attachments">
  <!-- Last Fetch / Validate Timestamps -->
<!-- <HBox id="_IDGenHBox1" alignItems="Center" class="sapUiSmallMarginBottom sapUiSmallMarginTop">
    <HBox id="_IDGenHBox3" alignItems="Center" visible="{oOpportunityjmodel>/lastValidateVisible}">
        <core:Icon id="_IDGenIcon1" src="sap-icon://accept" color="#107e3e" class="sapUiTinyMarginEnd"/>
        <Text id="_IDGenText75" text="Last Validated: {oOpportunityjmodel>/lastValidateTime}"/>
    </HBox>
</HBox> -->
  <OverflowToolbar id="_IDGenOverflowToolbar">
    <!-- <ToolbarSpacer id="_IDGenToolbarSpacer"/>
    <Button id="IDverify" text="Fetch/Validate CA" press="onfetchCA" type="Ghost"/> -->
    <ToolbarSpacer id="_IDGenToolbarSpacer"/>
        <!-- <core:Icon id="_IDGenIcon"  color="#0070b1" class="sapUiTinyMarginEnd" visible="{oOpportunityjmodel>/lastFetchVisible}"/>
        <Text id="_IDGenText74" text="Last Fetch: {oOpportunityjmodel>/lastFetchTime}" class="sapUiSmallMarginEnd" visible="{oOpportunityjmodel>/lastFetchVisible}"/> -->
    <Button id="idbtnCASort" icon="sap-icon://sort" type="Ghost"
            tooltip="Sort and Filter Contract Accounts"
            press="onSortFilterCA"/>
    <Button id="IDverify" text="Fetch/Validate CA" press="onfetchCA" type="Ghost"/>
  </OverflowToolbar>

  <Table id="tableISUCA" fixedLayout="false" growingThreshold="50" alternateRowColors="true"
         items="{oOpportunityjmodel>/ConsumptionDetails}">
    <columns>
      <Column id="_IDGenColumn2">
        <!-- Select All checkbox in column header -->
        <CheckBox id="idSelectAllCA" selected="false" select="onSelectAllCA"
                  tooltip="Select / Deselect all Contract Accounts"/>
      </Column>
      <Column id="_IDGenColumn3" sortIndicator="None">
        <Text id="_IDGenText6" text="{i18n>conacc}"/>
      </Column>
      <Column id="_IDGenColumn4" sortIndicator="None">
        <Text id="_IDGenText7" text="{i18n>buspartner}"/>
      </Column>
      <Column id="_IDGenColumn5" sortIndicator="None">
        <Text id="_IDGenText8" text="{i18n>estusage}"/>
      </Column>
      <Column id="_IDGenColumn6"><Text id="_IDGenText10" text="Metered"/></Column>
      <Column id="_IDGenColumn7"><Text id="_IDGenText11" text="60-Day Arrear"/></Column>
      <Column id="_IDGenColumn8"><Text id="_IDGenText12" text="2-NSF"/></Column>
      <Column id="_IDGenColumn9"><Text id="_IDGenText13" text="{i18n>replCA}"/></Column>
      <Column id="_IDGenColumn10"><Text id="_IDGenText14" text="Inactive"/></Column>
      <!-- <Column id="_IDGenColumn11"><Text id="_IDGenText15" text="{i18n>c20}"/></Column> -->
      <!-- <Column id="_IDGenColumn12"><Text id="_IDGenText16" text="{i18n>pcid}"/></Column> -->
      <Column id="_IDGenColumn13">
        <Text id="_IDGenText17" text="Enrolled"
              tooltip="Values from CR&amp;B e.g. MIGP-FIXED, MIGP-FLEX, LCVP"/>
      </Column>
      <!-- <Column id="_IDGenColumn14"><Text id="_IDGenText18" text="{i18n>val}"/></Column> -->
    </columns>
    <items>
      <ColumnListItem id="_IDGenColumnListItem1">
        <cells>
          <CheckBox id="_IDGenCheckBox"
                    selected="{path: 'oOpportunityjmodel>selected', type: 'sap.ui.model.type.Boolean'}"
                    select="onCARowSelect"/>
          <Text id="_IDGenText19" text="{oOpportunityjmodel>contacc}"/>
          <Text id="_IDGenText20" text="{oOpportunityjmodel>buspartner}"/>
          <Text id="_IDGenText21" text="{oOpportunityjmodel>est12month}"/>
          <Text id="_IDGenText22" text="{oOpportunityjmodel>metered}"/>
          <Text id="_IDGenText23" text="{oOpportunityjmodel>arrear60}"/>
          <Text id="_IDGenText24" text="{oOpportunityjmodel>nsfFlag}"/>
          <Text id="_IDGenText25" text="{oOpportunityjmodel>replacementCA}"/>
          <Text id="_IDGenText26" text="{oOpportunityjmodel>inactive}"/>
          <!-- <Text id="_IDGenText27" text="{oOpportunityjmodel>cycle20}"/> -->
          <!-- <Text id="_IDGenText28" text="{oOpportunityjmodel>providercontractId}"/> -->
          <Text id="_IDGenText29" text="{oOpportunityjmodel>enrolled}"/>
          <!-- <Text id="_IDGenText30" text="{oOpportunityjmodel>validity}"/> -->
        </cells>
      </ColumnListItem>
    </items>
  </Table>

          <Table id="tablesaveCA" growingThreshold="50" visible="false" alternateRowColors="true"
                 items="{oOpportunityjmodel>/ConsumptionDetails}">
            <columns>
              <Column id="_IDGenColumn15"><Text id="_IDGenText31" text="{i18n>conacc}"/></Column>
              <Column id="_IDGenColumn16"><Text id="_IDGenText32" text="{i18n>buspartner}"/></Column>
              <Column id="_IDGenColumn17"><Text id="_IDGenText33" text="{i18n>val}"/></Column>
              <Column id="_IDGenColumn18"><Text id="_IDGenText34" text="{i18n>replCA}"/></Column>
              <Column id="_IDGenColumn19"><Text id="_IDGenText35" text="{i18n>estusage}"/></Column>
              <Column id="_IDGenColumn20"><Text id="_IDGenText36" text="{i18n>met}"/></Column>
              <Column id="_IDGenColumn21"><Text id="_IDGenText37" text="{i18n>unmet}"/></Column>
            </columns>
            <items>
              <ColumnListItem id="_IDGenColumnListItem2">
                <cells>
                  <Text id="_IDGenText38" text="{oOpportunityjmodel>contacc}"/>
                  <Text id="_IDGenText39" text="{oOpportunityjmodel>buspartner}"/>
                  <Text id="_IDGenText40" text="{oOpportunityjmodel>validity}"/>
                  <Text id="_IDGenText41" text="{oOpportunityjmodel>replacementCA}"/>
                  <Text id="_IDGenText42" text="{oOpportunityjmodel>est12month}"/>
                  <Text id="_IDGenText43" text="{oOpportunityjmodel>metered}"/>
                  <Text id="_IDGenText44" text="{oOpportunityjmodel>cycle20}"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>

        </IconTabFilter>

        <IconTabSeparator id="_IDGenIconTabSeparator1"/>

        <!-- ── TAB 3: Provider Contract (FDD Tab#3) ───────────────────── -->
        <IconTabFilter id="_IDGenIconTabFilter3" text="Provider Contract" key="notes">

          <OverflowToolbar id="_IDGenOverflowToolbar1">
            <ToolbarSpacer id="_IDGenToolbarSpacer1"/>
            <Button id="idbtnPCSort" icon="sap-icon://sort" type="Ghost"
            tooltip="Sort and Filter Provider Contracts"
            press="onSortFilterPC"/>
   
            <!-- Cycle20 and Enroll buttons removed — no auto/manual enrollment per design change -->
            <Button id="IDcalculate" text="Calculate" press="oncalc" type="Ghost"/>
          </OverflowToolbar>

          <!-- SMB table -->
          <Table id="tablesmall" fixedLayout="false" visible="false" items="{oOpportunityjmodel>/ProviderContracts}">
            <columns>
              <Column id="_IDGenColumn22"><Text id="_IDGenText45" text="Product"/></Column>
              <Column id="_IDGenColumn23"><Text id="_IDGenText46" text="Portfolio"/></Column>
              <Column id="_IDGenColumn24"><Text id="_IDGenText47" text="Fixed $"/></Column>
              <Column id="colNetPremium"><Text id="_IDGenText74" text="Net Premium $/MWh"/></Column>
              <Column id="_IDGenColumn25"><Text id="_IDGenText48" text="Subscription Fee ($/MWh)"/></Column>
              <Column id="_IDGenColumn26"><Text id="_IDGenText49" text="Subscription %"/></Column>
              <Column id="_IDGenColumn27"><Text id="_IDGenText50" text="Start Date"/></Column>
